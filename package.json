{
  "name": "whyrl",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "postinstall": "patch-package"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-purchases|@revenuecat/.*))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "@react-native-async-storage/async-storage": "@react-native-async-storage/async-storage/jest/async-storage-mock"
    }
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/metro-runtime": "~56.0.14",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "expo": "^56.0.9",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "^56.0.19",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "^56.0.13",
    "expo-notifications": "~56.0.17",
    "expo-router": "^56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-tracking-transparency": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-google-mobile-ads": "^14.11.0",
    "react-native-purchases": "^10.1.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.14",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "patch-package": "^8.0.1"
  }
}
