{
  "expo": {
    "name": "Whyrl",
    "slug": "whyrl",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "whyrl",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
